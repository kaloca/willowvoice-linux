[Unit]
Description=KDE hold-to-talk shortcut bridge for Willow Voice
After=plasma-kglobalaccel.service willow-ydotoold.service
Wants=plasma-kglobalaccel.service willow-ydotoold.service
PartOf=graphical-session.target

[Service]
Type=exec
ExecStart="@LIBEXEC@/willow-dictate-ptt" --bridge "@LIBEXEC@/willow-dictate"
ExecStop="@LIBEXEC@/willow-dictate" reset
ExecStopPost="@LIBEXEC@/willow-dictate" reset
Restart=on-failure
RestartSec=1
TimeoutStopSec=10
UMask=0077
NoNewPrivileges=true
RestrictSUIDSGID=true

[Install]
WantedBy=graphical-session.target
