[Unit]
Description=Private keyboard injection service for Willow Voice
PartOf=graphical-session.target

[Service]
Type=exec
ExecStart=/usr/bin/ydotoold --socket-path=%t/willow-ydotool/ydotool.sock --socket-perm=0600 --mouse-off
Restart=on-failure
RestartSec=1
RuntimeDirectory=willow-ydotool
RuntimeDirectoryMode=0700
UMask=0077
NoNewPrivileges=true
LockPersonality=true
RestrictSUIDSGID=true

[Install]
WantedBy=graphical-session.target
